# SharkID Environment Configuration
# Generated during installation - modify as needed

# Database
DATABASE_URL=postgresql://sharkid:__DB_PASSWORD__@localhost/sharkid

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE=ml_jobs

# JWT Authentication
JWT_SECRET=__JWT_SECRET__
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=43200

# Storage
STORAGE_DIR=/opt/sharkid/data

# Application
DEBUG=false
